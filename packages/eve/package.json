{
  "name": "@archildata/eve",
  "version": "0.0.4",
  "description": "Archil filesystem adapter for eve",
  "keywords": [
    "archil",
    "eve",
    "agent",
    "filesystem"
  ],
  "homepage": "https://archil.com",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/archil-data/archil-sdk"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "disk": "workspace:*",
    "eve": ">=0.20.0"
  },
  "devDependencies": {
    "@archildata/mock": "workspace:*",
    "@types/node": "^20.19.33",
    "disk": "workspace:*",
    "eve": "^0.20.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">= 22"
  }
}
