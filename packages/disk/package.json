{
  "name": "disk",
  "version": "0.8.18",
  "description": "Pure-JS client and CLI for Archil disks",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.mts",
      "import": "./dist/ai-sdk.mjs",
      "require": "./dist/ai-sdk.cjs"
    },
    "./internal/tools": {
      "types": "./dist/internal/tools.d.mts",
      "import": "./dist/internal/tools.mjs",
      "require": "./dist/internal/tools.cjs"
    },
    "./mastra": {
      "types": "./dist/mastra.d.mts",
      "import": "./dist/mastra.mjs",
      "require": "./dist/mastra.cjs"
    },
    "./langchain": {
      "types": "./dist/langchain.d.mts",
      "import": "./dist/langchain.mjs",
      "require": "./dist/langchain.cjs"
    }
  },
  "bin": {
    "disk": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@archildata/api-types": "^0.0.1",
    "commander": "^14.0.3",
    "fast-xml-parser": "^4.5.1",
    "openapi-fetch": "^0.13.5",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "@mastra/core": ">=1.0.0",
    "ai": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "@mastra/core": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^1.2.1",
    "@mastra/core": "^1.47.0",
    "@types/node": "^26.0.1",
    "ai": "^7.0.5",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">= 22"
  },
  "keywords": [
    "archil",
    "disk",
    "filesystem",
    "cli"
  ],
  "license": "MIT"
}
