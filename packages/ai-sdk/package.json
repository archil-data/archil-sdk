{
  "name": "@archildata/ai-sdk",
  "version": "0.0.3",
  "description": "Archil filesystem adapter for AI SDK",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "ai": "^7.0.0",
    "disk": "workspace:*"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@archildata/mock": "workspace:*",
    "@types/node": "^20.19.43",
    "ai": "^7.0.15",
    "disk": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">= 22"
  },
  "keywords": [
    "archil",
    "ai sdk",
    "agent",
    "filesystem"
  ],
  "license": "MIT"
}
