{
  "name": "@archildata/langchain",
  "version": "0.0.2",
  "description": "Archil filesystem adapter for LangChain",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "disk": "workspace:*"
  },
  "devDependencies": {
    "@archildata/mock": "workspace:*",
    "@langchain/core": "^1.2.1",
    "@types/node": "^20.19.33",
    "disk": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">= 22"
  },
  "keywords": [
    "archil",
    "langchain",
    "agent",
    "filesystem"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^4.4.3"
  }
}
