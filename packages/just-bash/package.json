{
  "name": "@archildata/just-bash",
  "version": "0.8.18",
  "description": "Archil filesystem adapter for just-bash",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "archil-shell": "./dist/shell.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "shell": "tsx bin/shell.ts"
  },
  "dependencies": {
    "@archildata/native": "^0.8.18",
    "disk": "workspace:^",
    "commander": "^14.0.3",
    "debug": "^4.3.4",
    "just-bash": "^2.7.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "tsdown": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  },
  "keywords": [
    "archil",
    "just-bash",
    "filesystem",
    "bash",
    "ai-agents"
  ],
  "license": "MIT"
}
